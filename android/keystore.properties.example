# 릴리스 서명 설정 예시 — 이 파일을 복사해 android/keystore.properties 를 만들고 값을 채우세요.
#   cp android/keystore.properties.example android/keystore.properties
# ⚠️ keystore.properties 와 .jks 파일은 절대 깃/외부에 공유하지 마세요 (.gitignore 처리됨).
#    비밀번호를 잃어버리면 같은 서명으로 업데이트할 수 없습니다.

# keytool 로 만든 키스토어 파일의 절대 경로
storeFile=/Users/ipentech/keys/biblemem-release.jks
# 키스토어 비밀번호
storePassword=여기에_키스토어_비밀번호
# 키 별칭 (keytool -alias 값)
keyAlias=biblemem
# 키 비밀번호 (보통 키스토어 비밀번호와 동일하게 설정)
keyPassword=여기에_키_비밀번호
